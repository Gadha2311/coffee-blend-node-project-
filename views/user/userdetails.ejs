    </div> -->
    <!--PreLoader Ends-->
	
	<!-- header -->
	<div class="top-header-area" id="sticker">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-sm-12 text-center">
					<div class="main-menu-wrap">
						<!-- <a class="navbar-brand" href="index.html">Coffee<small>Blend</small></a> -->
						<!-- logo -->
						<div class="site-logo">
							<a href="index.html">
								<img src="" alt="">
							</a>
						</div>
						<!-- logo -->

						<!-- menu start -->
						<nav class="main-menu">
							<ul>
								<li class="current-list-item"><a href="/">Home</a></li>
								<li><a href="#">Menu</a></li>
								<li><a href="/shop">Shop</a></li>
								<li><a href="contact.html">Contact</a></li>
								<li><a href="#">category</a>
									<ul class="sub-menu">
										<li class="nav-item">
											<% categories.filter(category => category.status !== false).forEach(category => { %>
												<a class="dropdown-item" href="/shop?category=<%= category._id %>">
												<%= category.name %>
												</a>
												<% }); %>
								        </li>
									</ul>
								</li>
								<li>
									<div class="header-icons">
										<a class="shopping-cart" href="/cart"><i class="fas fa-shopping-cart"></i></a>
										<a class="mobile-hide search-bar-icon" href="#"><i class="fas fa-search"></i></a>
										<a class="mobile-hide search-bar-icon" href="#"><i class="fas fa-heart"></i></a>
                                        <a class="mobile-hide search-bar-icon" href="/profile"><i class="fas fa-user"></i></a>
									</div>
								</li>
							</ul>
						</nav>
						<a class="mobile-show search-bar-icon" href="#"><i class="fas fa-search"></i></a>
						<div class="mobile-menu"></div>
						<!-- menu end -->
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- end header -->


    <!-- User Details Section -->
<div class="row">
    <div class="col-lg-6">
      <section id="lineone" class=" user-details-section mt-4 section-container d-flex align-items-stretch">
        <div class="section-half">
          <h3>Your Profile</h3>
          <!-- Personal details -->
          <div class="personal-details">
            <p><%= userData.email %></p>
            <p><%= userData.username %></p>
            <!-- <p>Date of Birth: January 1, 1990</p>
            <p>Gender: Male</p> -->
            <a href="/editProfile" class="btn btn-primary">Edit your details</a>
          </div>
        </div>
      </section>
    </div>
  
    <div class="col-lg-6">
      <section id="lineone" class="user-details-section mt-4 section-container d-flex align-items-stretch">
        <div class="section-half">
          <h4>Saved Addresses</h4>
          <!-- Saved addresses -->
          <ul>
            <% userData.address.forEach(function(address) { %>
              <li class="address-list">
                <div class="address-section">
                  <div class="address-content">
                    <p><%= address.saveas %></p>
                    <div class="address-icons">
                      <a class="edit" href="/editaddress/<%= address._id %>"><img src="images/icons8-edit-40.png" alt="Edit Icon"></a>
                      <a class="delete" href="/deleteaddress/<%= address._id %>"><img src="images/icons8-delete-40.png" alt="Delete Icon"></a>
                    </div>
                  </div>
                </div>
              </li>
            <% }); %>
          </ul>
          
  
          <a href="/addAddress" class="btn btn-primary">Add new address</a>
        </div>
      </section>
    </div>
  </div>
  
  <section class="user-details-section mt-4 section-container">
    <div class="section-half">
      <h4>Password</h4>
      <!-- Password management -->
      <p>Email:  <%= userData.email %></p>
      <p>Password: ********</p>
      <button id="changePasswordLink" type="button" class="btn btn-warning" onclick="togglePasswordForm()">Change Password</button>
      <br><br>
  
      <!-- Password change form -->
      <form action="/cp" method="post" id="passwordForm" class="passwordForm">
        <label for="newPassword">Enter old Password:</label>
        <input type="password" id="newPassword" name="newPassword" required>
        <% if(locals.perror){ %>
        <div class="alter text-danger text-start"><%= perror %></div>
        <% } %>
  
        <label for="confirmPassword">New Password:</label>
        <input type="password" id="confirmPassword" name="confirmPassword" required>
        <% if(locals.cperror){ %>
        <div class="alter text-danger text-start"><%= cperror %></div>
        <% } %>
  
        <br><br>
  
        <button type="submit" class="btn btn-warning">Submit</button>
      </form>
    </div>
  </section>
    </div>


    <!-- footer -->
	<div class="footer-area">
		<div class="container">
			<div class="row">
				<div class="col-lg-3 col-md-6">
					<div class="footer-box about-widget">
						<h2 class="widget-title">About us</h2>
						<p>Far far away, behind the word mountains, far from the countries Vokalia and Consonantia, there live the blind texts.</p>
					</div>
				</div>
				<div class="col-lg-3 col-md-6">
					<div class="footer-box get-in-touch">
						<h2 class="widget-title">Get in Touch</h2>
						<ul>
							<li>203 Fake St. Mountain View, San Francisco, California, USA.</li>
							<li>support@coffeeblenf.com</li>
							<li>+00 111 222 3333</li>
						</ul>
					</div>
				</div>
				<div class="col-lg-3 col-md-6">
					<div class="footer-box pages">
						<h2 class="widget-title">Pages</h2>
						<ul>
							<li><a href="index.html">Home</a></li>
							<li><a href="about.html">Menu</a></li>
							<li><a href="services.html">Shop</a></li>
							<li><a href="contact.html">Contact</a></li>
						</ul>
					</div>
				</div>
				<div class="col-lg-3 col-md-6">
					<div class="footer-box subscribe">
						<h2 class="widget-title">Subscribe</h2>
						<p>Subscribe to our mailing list to get the latest updates.</p>
						<form action="index.html">
							<input type="email" placeholder="Email">
							<button type="submit"><i class="fas fa-paper-plane"></i></button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
